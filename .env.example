# Copy this file to .env and fill in your values.
# NEVER commit .env — it is git-ignored.

# Alembic + SQLAlchemy connection (uses psycopg3 driver)
DATABASE_URL=postgresql+psycopg://postgres:yourpassword@localhost:5433/clinic_db

# Docker container credentials (must match DATABASE_URL above)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=yourpassword
POSTGRES_DB=clinic_db
